---
import Nav from "./Nav.astro";
import CardNoticias from "../../components/CardNoticias.astro";
import AnimationTextHeader from "../../components/AnimationTextHeader.astro";
//Imagenes
import Index from "../../assets/page/bg.jpg";
import QuienesSomos from "../../assets/page/QuienesSomos.png";
import Organigrama from "../../assets/page/Organigrama.png";
const path = Astro.url.pathname;
let bg = "";
let title = "";
let breadcrumbTitle = "";

switch (path) {
    case "/":
        bg = Index.src;
        break;
    case "/QuienesSomos":
        bg = QuienesSomos.src;
        title = "¿QUIÉNES SOMOS?";
        breadcrumbTitle = "Quienes somos";
        break;
    case "/Organigrama":
        bg = Organigrama.src;
        title = "ORGANIGRAMA";
        breadcrumbTitle = "Organigrama";
        break;
    case "/PoliticaGestionIntegrado":
        bg = Organigrama.src;
        title = "POLÍTICA DE GESTIÓN INTEGRADO";
        breadcrumbTitle = "Política de Gestión Integrado";
        break;
    case "/contacto":
    case "/Contacto":
        bg = Index.src;
        title = "CONTACTO";
        breadcrumbTitle = "Contacto";
        break;
    default:
        bg = Index.src;
        title = path.replace(/\//g, "").toUpperCase();
        const rawPath = path.replace(/\//g, "");
        breadcrumbTitle = rawPath
            ? rawPath.charAt(0).toUpperCase() + rawPath.slice(1).toLowerCase()
            : "";
        break;
}

const isHome = path === "/";
---

<div
    class={`relative w-full overflow-hidden ${isHome ? "min-h-[74vh]" : "min-h-[60vh]"} bg-cover bg-center bg-no-repeat flex flex-col`}
    style={`background-image: url(${bg});`}
>
    <Nav />
    {
        isHome ? (
            <section class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 pb-4 pt-10 lg:pt-16 flex flex-row items-start justify-between gap-4 lg:gap-0 w-full flex-grow">
                <AnimationTextHeader />
                <CardNoticias />
            </section>
        ) : (
            <section class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-12 flex flex-col items-center justify-center w-full flex-grow pb-32 lg:pb-48 gap-2">
                <h1 class="text-white text-4xl md:text-5xl lg:text-6xl font-black text-center drop-shadow-[0_5px_5px_rgba(0,0,0,0.8)] tracking-wide">
                    {title}
                </h1>
                <div class="flex items-center gap-2 text-white text-base md:text-xl font-medium tracking-wide drop-shadow-md mt-5">
                    <span>JAM</span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-4 h-4 md:w-5 md:h-5 text-[#DE5B6D]"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 5l7 7-7 7"
                        />
                    </svg>
                    <span>{breadcrumbTitle}</span>
                </div>
            </section>
        )
    }
</div>
