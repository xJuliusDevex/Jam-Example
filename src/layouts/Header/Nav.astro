---
import Search from "../../components/Icon/Search.svg";
import JAM from "../../assets/L_JAM.png";
import raya from "../../assets/raya.png";
---

<nav
    id="mainNav"
    class="relative w-full bg-white lg:bg-[#631322c7] shadow-md border-b-[0.5px] border-gray-100 lg:border-white/70 z-50 transition-all duration-300"
>
    <div
        class="max-w-7xl mx-auto px-6 lg:px-12 py-3 lg:py-4 flex items-center justify-between"
    >
        <!-- Mobile Logo -->
        <a href="/" class="flex lg:hidden items-center gap-1">
            <img src={JAM.src} alt="logo" width="50px" height="40px" />
            <img src={raya.src} alt="raya" width="1px" height="30px" />
            <div
                class="text-[#EC5463] font-bold uppercase leading-none text-[11px]"
            >
                <p>Construcciones</p>
                <p>Ingeniería y</p>
                <p>Servicios</p>
            </div>
        </a>

        <!-- Main Navigation Links (Desktop) -->
        <ul
            class="hidden lg:flex flex-wrap items-center gap-4 lg:gap-10 text-xs sm:text-sm font-black uppercase tracking-widest text-white"
        >
            <li>
                <a href="/" class="hover:text-gray-200 transition">INICIO</a>
            </li>
            <li class="relative group">
                <a
                    href="#"
                    class="hover:text-gray-200 transition flex items-center gap-1"
                >
                    JAM
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-4 h-4 transition-transform group-hover:rotate-180"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>

                <!-- Dropdown Menu wrapper to bridge the gap -->
                <div
                    class="absolute left-0 top-full w-64 pt-6 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 font-medium normal-case tracking-normal text-left"
                >
                    <ul
                        class="bg-white rounded-xl shadow-2xl overflow-hidden py-2 border border-gray-100 flex flex-col"
                    >
                        <li>
                            <a
                                href="/QuienesSomos"
                                class="block px-5 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#DE5B6D] transition-colors"
                            >
                                ¿Quienes somos?
                            </a>
                        </li>
                        <li>
                            <a
                                href="#"
                                class="block px-5 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#DE5B6D] transition-colors"
                            >
                                Organigrama
                            </a>
                        </li>
                        <li>
                            <a
                                href="#"
                                class="block px-5 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#DE5B6D] transition-colors leading-relaxed"
                            >
                                Política de Gestión Integrado
                            </a>
                        </li>
                    </ul>
                </div>
            </li>
            <li>
                <a href="#" class="hover:text-gray-200 transition">SERVICIOS</a>
            </li>
            <li>
                <a href="#" class="hover:text-gray-200 transition">NOTICIAS</a>
            </li>
            <li>
                <a href="#" class="hover:text-gray-200 transition">CONTACTO</a>
            </li>
        </ul>
        <!-- Right Action Items -->
        <div class="flex items-center gap-4">
            <!-- Mobile Menu Toggle -->
            <div class="flex items-center gap-2">
                <input
                    type="text"
                    id="searchInput"
                    placeholder="Buscar..."
                    class="w-0 opacity-0 overflow-hidden transition-all duration-300 ease-in-out bg-gray-100 lg:bg-white/20 text-gray-800 lg:text-white placeholder-gray-400 lg:placeholder-white/70 rounded-full px-0 py-1.5 focus:outline-none focus:ring-1 focus:ring-gray-300 lg:focus:ring-white/50"
                />
                <button
                    id="searchToggleBtn"
                    class="text-[#DE5B6D] lg:text-white hover:text-[#c44958] lg:hover:text-gray-200 transition focus:outline-none p-2 rounded-full lg:hover:bg-white/10"
                    aria-label="Buscar"
                >
                    <Search />
                </button>
            </div>
            <button
                id="mobileMenuToggleBtn"
                class="block lg:hidden text-[#EC5463] focus:outline-none p-1 transition-transform"
                aria-label="Menu"
            >
                <!-- Hamburger Icon -->
                <svg
                    id="menuIconBars"
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-8 h-8 block"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <!-- Close Icon -->
                <svg
                    id="menuIconClose"
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-8 h-8 hidden"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <!-- Dynamic Search Block -->
        </div>
    </div>

    <!-- Dropdown Mobile Menu -->
    <div
        id="mobileMenuContainer"
        class="absolute left-0 right-0 top-full bg-[#333333] lg:hidden transition-all duration-300 origin-top opacity-0 pointer-events-none -translate-y-2 border-t border-[#444444]"
        data-expanded="false"
    >
        <ul
            class="flex flex-col text-white font-medium text-[15px] pt-8 pb-10 px-8 gap-8 tracking-wide"
        >
            <li>
                <a
                    href="#"
                    class="block hover:text-[#EC5463] transition-colors mobile-menu-link"
                    >INICIO</a
                >
            </li>
            <li>
                <div
                    id="mobileSubmenuToggleJAM"
                    class="flex justify-between items-center cursor-pointer"
                >
                    <span class="hover:text-[#EC5463] transition-colors"
                        >JAM</span
                    >
                    <svg
                        id="mobileChevronJAM"
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5 text-gray-300 transition-transform duration-300"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
                <!-- Submenu items -->
                <ul
                    id="mobileSubmenuJAM"
                    class="flex flex-col gap-5 text-gray-300 text-[14px] font-normal overflow-hidden transition-all duration-300 max-h-0 opacity-0 mt-0 pl-4 border-l border-[#555] ml-2"
                >
                    <li class="pt-4">
                        <a
                            href="/QuienesSomos"
                            class="block hover:text-white transition-colors mobile-menu-link"
                            >¿Quienes somos?</a
                        >
                    </li>
                    <li>
                        <a
                            href="#"
                            class="block hover:text-white transition-colors mobile-menu-link"
                            >Organigrama</a
                        >
                    </li>
                    <li>
                        <a
                            href="#"
                            class="block hover:text-white transition-colors mobile-menu-link"
                            >Política de Gestión Integrado</a
                        >
                    </li>
                </ul>
            </li>
            <li>
                <a
                    href="#"
                    class="block hover:text-[#EC5463] transition-colors mobile-menu-link"
                    >SERVICIOS</a
                >
            </li>
            <li>
                <a
                    href="#"
                    class="block hover:text-[#EC5463] transition-colors mobile-menu-link"
                    >TRABAJA CON NOSOTROS</a
                >
            </li>
            <li>
                <a
                    href="/contacto"
                    class="block hover:text-[#EC5463] transition-colors mobile-menu-link"
                    >CONTACTO</a
                >
            </li>
        </ul>
    </div>
</nav>

<script>
    // Search bar logic
    const searchToggleBtn = document.getElementById("searchToggleBtn");
    const searchInput = document.getElementById("searchInput");
    if (searchToggleBtn && searchInput) {
        searchToggleBtn.addEventListener("click", () => {
            // Utilizamos data-expanded para rastrear el estado eficientemente
            const isExpanded =
                searchInput.getAttribute("data-expanded") === "true";
            if (isExpanded) {
                searchInput.classList.remove(
                    "w-[140px]",
                    "sm:w-[180px]",
                    "md:w-[240px]",
                    "opacity-100",
                    "px-4",
                );
                searchInput.classList.add("w-0", "opacity-0", "px-0");
                searchInput.setAttribute("data-expanded", "false");
            } else {
                searchInput.classList.remove("w-0", "opacity-0", "px-0");
                searchInput.classList.add(
                    "w-[95px]",
                    "sm:w-[180px]",
                    "md:w-[240px]",
                    "opacity-100",
                    "px-4",
                );
                searchInput.setAttribute("data-expanded", "true");
                searchInput.focus();
            }
        });
    }

    // Mobile Menu Logic
    const mobileMenuToggleBtn = document.getElementById("mobileMenuToggleBtn");
    const mobileMenuContainer = document.getElementById("mobileMenuContainer");
    const menuIconBars = document.getElementById("menuIconBars");
    const menuIconClose = document.getElementById("menuIconClose");
    const mobileLinks = document.querySelectorAll(".mobile-menu-link");

    // Submenu Logic DOM Elements
    const mobileSubmenuToggleJAM = document.getElementById(
        "mobileSubmenuToggleJAM",
    );
    const mobileSubmenuJAM = document.getElementById("mobileSubmenuJAM");
    const mobileChevronJAM = document.getElementById("mobileChevronJAM");

    const toggleMobileMenu = () => {
        if (!mobileMenuContainer) return;
        const isExpanded =
            mobileMenuContainer.getAttribute("data-expanded") === "true";

        if (isExpanded) {
            // Close Menu
            mobileMenuContainer.classList.remove(
                "opacity-100",
                "pointer-events-auto",
                "translate-y-0",
            );
            mobileMenuContainer.classList.add(
                "opacity-0",
                "pointer-events-none",
                "-translate-y-2",
            );
            mobileMenuContainer.setAttribute("data-expanded", "false");

            if (menuIconBars) {
                menuIconBars.classList.remove("hidden");
                menuIconBars.classList.add("block");
            }
            if (menuIconClose) {
                menuIconClose.classList.remove("block");
                menuIconClose.classList.add("hidden");
            }

            // Close submenu automatically
            if (
                mobileSubmenuJAM &&
                !mobileSubmenuJAM.classList.contains("max-h-0")
            ) {
                mobileSubmenuJAM.classList.add("max-h-0", "opacity-0", "mt-0");
                mobileSubmenuJAM.classList.remove(
                    "max-h-[300px]",
                    "opacity-100",
                    "mt-2",
                );
                if (mobileChevronJAM)
                    mobileChevronJAM.classList.remove("rotate-180");
            }
        } else {
            // Open Menu
            mobileMenuContainer.classList.remove(
                "opacity-0",
                "pointer-events-none",
                "-translate-y-2",
            );
            mobileMenuContainer.classList.add(
                "opacity-100",
                "pointer-events-auto",
                "translate-y-0",
            );
            mobileMenuContainer.setAttribute("data-expanded", "true");

            if (menuIconBars) {
                menuIconBars.classList.remove("block");
                menuIconBars.classList.add("hidden");
            }
            if (menuIconClose) {
                menuIconClose.classList.remove("hidden");
                menuIconClose.classList.add("block");
            }
        }
    };

    if (mobileMenuToggleBtn && mobileMenuContainer) {
        mobileMenuToggleBtn.addEventListener("click", toggleMobileMenu);
    }

    // Toggle Submenu click event
    if (mobileSubmenuToggleJAM && mobileSubmenuJAM && mobileChevronJAM) {
        mobileSubmenuToggleJAM.addEventListener("click", () => {
            const isSubExpanded =
                !mobileSubmenuJAM.classList.contains("max-h-0");
            if (isSubExpanded) {
                // Collapse
                mobileSubmenuJAM.classList.add("max-h-0", "opacity-0", "mt-0");
                mobileSubmenuJAM.classList.remove(
                    "max-h-[300px]",
                    "opacity-100",
                    "mt-2",
                );
                mobileChevronJAM.classList.remove("rotate-180");
            } else {
                // Expand
                mobileSubmenuJAM.classList.remove(
                    "max-h-0",
                    "opacity-0",
                    "mt-0",
                );
                mobileSubmenuJAM.classList.add(
                    "max-h-[300px]",
                    "opacity-100",
                    "mt-2",
                );
                mobileChevronJAM.classList.add("rotate-180");
            }
        });
    }

    // Close menu when a standard link is clicked
    mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
            if (
                mobileMenuContainer &&
                mobileMenuContainer.getAttribute("data-expanded") === "true"
            ) {
                toggleMobileMenu();
            }
        });
    });

    // Sticky Navigation Logic
    const mainNav = document.getElementById("mainNav");
    if (mainNav && mainNav.parentNode) {
        const placeholder = document.createElement("div");
        placeholder.className = "hidden";
        mainNav.parentNode.insertBefore(placeholder, mainNav);

        window.addEventListener("scroll", () => {
            if (window.scrollY > 40) {
                if (!mainNav.classList.contains("fixed")) {
                    placeholder.style.height = `${mainNav.offsetHeight}px`;
                    placeholder.className = "block w-full"; // Show placeholder
                    mainNav.classList.remove("relative");
                    mainNav.classList.add(
                        "fixed",
                        "top-0",
                        "left-0",
                        "z-[100]",
                        "animate-fade-in",
                    );
                }
            } else {
                if (mainNav.classList.contains("fixed")) {
                    placeholder.className = "hidden";
                    mainNav.classList.add("relative");
                    mainNav.classList.remove(
                        "fixed",
                        "top-0",
                        "left-0",
                        "z-[100]",
                        "animate-fade-in",
                    );
                }
            }
        });
    }
</script>
