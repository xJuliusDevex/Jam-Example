---
import Clock from "../../components/Icon/Clock.svg";
import Location from "../../components/Icon/Location.svg";
import Iso from "../../assets/iso_jam.png";
---

<footer id="animated-footer" class="bg-black w-full text-white py-12 opacity-0 translate-y-10 transition-all duration-700 ease-out">
    <div
        class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8"
    >
        <!-- Columna 1 -->
        <div class="flex flex-col gap-6">
            <div>
                <h2 class="text-2xl font-bold mb-2">JAM</h2>
                <p class="text-[#b3b3b3] italic text-[13px] mb-3">
                    "Jam" Construcción, Ingeniería y Servicio
                </p>
                <p class="text-[#b3b3b3] italic text-[13px] leading-snug">
                    Fue creada el 14 de Octubre 1994, con la finalidad de
                    prestar servicios a las diferentes empresas de la zona norte
                    del país.
                </p>
            </div>
            <div>
                <h2 class="text-2xl font-bold mb-4">Horario</h2>
                <p class="text-[#EC5463] text-[13px] mb-2">Lunes- Viernes</p>
                <div class="flex flex-col gap-2 mb-3">
                    <div
                        class="flex items-center gap-2 text-[#EC5463] text-[13px]"
                    >
                        <Clock class="w-4 h-4" />
                        <span>8:30am - 12:30pm</span>
                    </div>
                    <div
                        class="flex items-center gap-2 text-[#EC5463] text-[13px]"
                    >
                        <Clock class="w-4 h-4" />
                        <span>14:00pm - 17:30pm</span>
                    </div>
                </div>
                <p class="text-[#EC5463] text-[13px] mb-2">Sabado</p>
                <div class="flex items-center gap-2 text-[#EC5463] text-[13px]">
                    <Clock class="w-4 h-4" />
                    <span>8:30am - 12:30pm</span>
                </div>
            </div>
        </div>

        <!-- Columna 2 -->
        <div class="flex flex-col gap-6">
            <div>
                <h2 class="text-2xl font-bold mb-5">Contáctanos</h2>
                <div class="text-[13px] flex gap-2 mb-3">
                    <span class="text-[#EC5463] font-bold">Telefono:</span>
                    <div class="flex flex-col text-[#b3b3b3] gap-1">
                        <span>(+55 2) 210905</span>
                        <span>(+55 2) 481407</span>
                    </div>
                </div>
                <div class="flex gap-2 text-[13px] mb-3">
                    <span class="text-[#EC5463] font-bold">Movil:</span>
                    <span class="text-[#b3b3b3]">(+55 9) 9886 0038</span>
                </div>
                <div class="flex gap-2 text-[13px] mb-6">
                    <span class="text-[#EC5463] font-bold">Email:</span>
                    <a
                        href="mailto:francisco.avalos@jamincoser.cl"
                        class="text-[#b3b3b3] hover:underline underline-offset-2"
                        >francisco.avalos@jamincoser.cl</a
                    >
                </div>
            </div>
            <div>
                <h2 class="text-2xl font-bold mb-4">Ubicación</h2>
                <div class="flex items-start gap-2">
                    <Location class="w-4 h-4 text-[#EC5463]" />
                    <span class="text-[#b3b3b3] text-[13px]"
                        >Los Topacios # 680. La Chimba – Antofagasta</span
                    >
                </div>
            </div>
        </div>

        <!-- Columna 3 -->
        <div>
            <h2 class="text-2xl font-bold mb-5">Enlaces Rápidos</h2>
            <ul
                class="flex flex-col gap-4 text-[13px] font-bold text-[#b3b3b3]"
            >
                <li class="flex items-center gap-2">
                    <span
                        class="border-t-[5px] border-b-[5px] border-l-[6px] border-transparent border-l-[#EC5463] h-0 w-0"
                    ></span>
                    <a href="#" class="hover:text-white transition-colors"
                        >¿QUIENES SOMOS?</a
                    >
                </li>
                <li class="flex items-center gap-2">
                    <span
                        class="border-t-[5px] border-b-[5px] border-l-[6px] border-transparent border-l-[#EC5463] h-0 w-0"
                    ></span>
                    <a href="#" class="hover:text-white transition-colors"
                        >SERVICIOS</a
                    >
                </li>
                <li class="flex items-center gap-2">
                    <span
                        class="border-t-[5px] border-b-[5px] border-l-[6px] border-transparent border-l-[#EC5463] h-0 w-0"
                    ></span>
                    <a href="#" class="hover:text-white transition-colors"
                        >NOTICIAS</a
                    >
                </li>
                <li class="flex items-center gap-2">
                    <span
                        class="border-t-[5px] border-b-[5px] border-l-[6px] border-transparent border-l-[#EC5463] h-0 w-0"
                    ></span>
                    <a href="#" class="hover:text-white transition-colors"
                        >CONTACTO</a
                    >
                </li>
            </ul>
        </div>

        <!-- Columna 4 -->
        <div>
            <h2 class="text-2xl font-bold mb-5 flex justify-center">
                Estándares ISO
            </h2>
            <div class="flex justify-center lg:justify-start">
                <img
                    src={Iso.src}
                    alt="Estándares ISO"
                    class="w-full max-w-[280px] object-contain"
                />
            </div>
        </div>
    </div>
</footer>

<script>
    const footer = document.getElementById("animated-footer");
    if (footer) {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove("opacity-0", "translate-y-10");
                        entry.target.classList.add("opacity-100", "translate-y-0");
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.1 }
        );
        observer.observe(footer);
    }
</script>
