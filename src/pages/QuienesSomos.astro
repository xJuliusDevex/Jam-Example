---
import Layout from "../layouts/Layout.astro";
import LineaDivisor from "../components/LineaDivisor.astro";
import Title_Izq from "../components/Title_Izq.astro";
import MisionVisionValores from "../components/MisionVisionValores.astro";
import isoJam from "../assets/logoIso.png";
import TextImg from "../components/textImg.astro";
import img1 from "../assets/Quienes somos/img1.png";
import img2 from "../assets/Quienes somos/img2.png";
import img3 from "../assets/Quienes somos/img3.png";
import img4 from "../assets/Quienes somos/img4.png";
import img5 from "../assets/Quienes somos/img5.png";
import img6 from "../assets/Quienes somos/img6.png";
---

<Layout>
    <section class="w-full bg-[#fcfcfc] py-16 lg:py-24">
        <Title_Izq />
        <LineaDivisor />
        <MisionVisionValores />
        <LineaDivisor />
        <TextImg isoJam={isoJam} />
        <LineaDivisor />

        <!-- Infraestructura -->
        <div id="infra-container" class="max-w-7xl mx-auto px-6 lg:px-12 mt-16 lg:mt-24 pb-16 lg:pb-24 overflow-hidden">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center mb-12">
                <h2 class="infra-left text-3xl md:text-4xl lg:text-[40px] font-black text-[#DE5B6D] tracking-tight leading-tight text-left drop-shadow-sm uppercase opacity-0 -translate-x-[50px] transition-all duration-1000 ease-out">
                    Infraestructura de la<br/>Organizacion de JAM
                </h2>
                <p class="infra-right text-gray-500 font-bold leading-relaxed text-base lg:text-lg text-justify md:text-right opacity-0 translate-x-[50px] transition-all duration-1000 delay-200 ease-out">
                    La Gerencia JAM Ingeniería, Construcción y Servicio ha destinado los recursos necesarios para mejorar la infraestructura de la Organización y desarrollar la competencia de los cargos operativos de la organización.
                </p>
            </div>

            <!-- Image Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8 lg:gap-10 max-w-3xl mx-auto mt-12">
                {[img1, img2, img3, img4, img5, img6].map((img, index) => (
                    <div class="infra-img-item overflow-hidden bg-gray-100 shadow-md cursor-pointer group aspect-[4/3] rounded-sm relative opacity-0 translate-y-[50px] transition-all duration-700 ease-out" style={`transition-delay: ${200 + index * 100}ms`} data-gallery-img>
                        <img src={img.src} alt={`Infraestructura ${index + 1}`} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                        <!-- Lupa Icon Hover Overlay -->
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                            </svg>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300">
        <!-- Close btn -->
        <button id="lightbox-close" class="absolute top-4 right-4 md:top-8 md:right-8 text-white/70 hover:text-white transition-colors z-[110] p-2 bg-black/50 hover:bg-[#DE5B6D] rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        
        <!-- Prev btn -->
        <button id="lightbox-prev" class="absolute left-2 md:left-8 text-white/70 hover:text-white transition-colors z-[110] p-3 bg-black/50 hover:bg-[#DE5B6D] rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-12 md:h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
        </button>
        
        <!-- Image container -->
        <div class="relative w-full h-full max-h-[90vh] flex items-center justify-center px-16 md:px-32 select-none">
            <img id="lightbox-img" src="" alt="Vista ampliada" class="max-w-full max-h-full object-contain shadow-2xl transition-transform duration-300 scale-95" />
        </div>
        
        <!-- Next btn -->
        <button id="lightbox-next" class="absolute right-2 md:right-8 text-white/70 hover:text-white transition-colors z-[110] p-3 bg-black/50 hover:bg-[#DE5B6D] rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-12 md:h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
        </button>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const galleryItems = document.querySelectorAll('[data-gallery-img]');
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img');
            const btnClose = document.getElementById('lightbox-close');
            const btnPrev = document.getElementById('lightbox-prev');
            const btnNext = document.getElementById('lightbox-next');
            
            if(!lightbox || galleryItems.length === 0) return;

            let currentIndex = 0;
            const imageUrls = Array.from(galleryItems).map(item => item.querySelector('img').src);

            galleryItems.forEach((item, index) => {
                item.addEventListener('click', () => {
                    currentIndex = index;
                    openLightbox();
                });
            });

            function openLightbox() {
                updateImage();
                lightbox.classList.remove('hidden');
                lightbox.classList.add('flex');
                
                // Allow flex to apply before transitioning opacity
                setTimeout(() => {
                    lightbox.classList.remove('opacity-0');
                    lightboxImg.classList.remove('scale-95');
                    lightboxImg.classList.add('scale-100');
                }, 20);
                document.body.style.overflow = 'hidden';
            }

            function closeLightbox() {
                lightbox.classList.add('opacity-0');
                lightboxImg.classList.remove('scale-100');
                lightboxImg.classList.add('scale-95');
                
                setTimeout(() => {
                    lightbox.classList.remove('flex');
                    lightbox.classList.add('hidden');
                }, 300);
                document.body.style.overflow = '';
            }

            function updateImage() {
                lightboxImg.src = imageUrls[currentIndex];
            }

            function showPrev(e) {
                if(e) e.stopPropagation();
                currentIndex = (currentIndex === 0) ? imageUrls.length - 1 : currentIndex - 1;
                updateImage();
            }

            function showNext(e) {
                if(e) e.stopPropagation();
                currentIndex = (currentIndex === imageUrls.length - 1) ? 0 : currentIndex + 1;
                updateImage();
            }

            btnClose.addEventListener('click', closeLightbox);
            btnPrev.addEventListener('click', showPrev);
            btnNext.addEventListener('click', showNext);

            // Close on background click
            lightbox.addEventListener('click', (e) => {
                if (e.target === lightbox || e.target.closest('div.relative')) {
                    if(e.target.tagName !== 'IMG' && e.target.tagName !== 'BUTTON' && !e.target.closest('button')) {
                        closeLightbox();
                    }
                }
            });

            // Keyboard navigation
            document.addEventListener('keydown', (e) => {
                if (lightbox.classList.contains('hidden')) return;
                if (e.key === 'Escape') closeLightbox();
                if (e.key === 'ArrowLeft') showPrev();
                if (e.key === 'ArrowRight') showNext();
            });

            // Intersection Observer for Infraestructura section
            const infraContainer = document.getElementById('infra-container');
            if (infraContainer) {
                const infraLeft = infraContainer.querySelector('.infra-left');
                const infraRight = infraContainer.querySelector('.infra-right');
                const infraImgs = infraContainer.querySelectorAll('.infra-img-item');

                const infraObserver = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            infraLeft?.classList.remove('opacity-0', '-translate-x-[50px]');
                            infraLeft?.classList.add('opacity-100', 'translate-x-0');

                            infraRight?.classList.remove('opacity-0', 'translate-x-[50px]');
                            infraRight?.classList.add('opacity-100', 'translate-x-0');

                            infraImgs.forEach(img => {
                                img.classList.remove('opacity-0', 'translate-y-[50px]');
                                img.classList.add('opacity-100', 'translate-y-0');
                            });

                            infraObserver.disconnect();
                        }
                    });
                }, { threshold: 0.15 });
                
                infraObserver.observe(infraContainer);
            }
        });
    </script>
</Layout>
