---
import Layout from "../layouts/Layout.astro";
import LineaDivisor from "../components/LineaDivisor.astro";
import isoJam from "../assets/logoIso.png";
import img1 from "../assets/Quienes somos/img1.png";
import img2 from "../assets/Quienes somos/img2.png";
import img3 from "../assets/Quienes somos/img3.png";
import img4 from "../assets/Quienes somos/img4.png";
import img5 from "../assets/Quienes somos/img5.png";
import img6 from "../assets/Quienes somos/img6.png";
---

<Layout>
    <section class="w-full bg-[#fcfcfc] py-16 lg:py-24">
        <div
            class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center"
        >
            <!-- Columna Izquierda: Títulos -->
            <div
                class="flex flex-col items-center justify-center text-center space-y-1"
            >
                <h2
                    class="text-3xl md:text-4xl lg:text-5xl font-black text-[#1a1a1a] tracking-tight uppercase"
                >
                    ¿Quienes somos?
                </h2>
                <h3
                    class="text-3xl md:text-4xl lg:text-5xl font-black text-[#DE5B6D] tracking-tight uppercase"
                >
                    JAM
                </h3>
                <h4
                    class="text-2xl md:text-3xl lg:text-4xl font-black text-[#1a1a1a] tracking-tight leading-tight uppercase pt-2"
                >
                    Construcción, Ingeniería y<br />
                    Servicios
                </h4>
            </div>

            <!-- Columna Derecha: Párrafo -->
            <div
                class="text-center text-gray-500 font-medium leading-relaxed text-base lg:text-lg max-w-xl mx-auto"
            >
                <p>
                    <strong class="text-gray-600 font-bold"
                        >JAM Construcción, Ingeniería y Servicio</strong
                    >, fue creada el 14 de Octubre 1994 , con la finalidad de
                    prestar servicios a las diferentes empresas de la zona norte
                    del país. Su dependencia inicialmente se encontraba ubicada
                    en Lautaro Espíndola #7024 y hoy en día sus oficinas
                    administrativas y talleres operacionales en Los Topacios
                    680, Antofagasta.
                </p>
            </div>
        </div>
        <LineaDivisor />

        <!-- Misión, Visión, Valores -->
        <div
            class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16 items-start mt-16 lg:mt-24"
        >
            <!-- Misión -->
            <div class="flex flex-col">
                <h3
                    class="text-3xl lg:text-4xl font-black text-[#DE5B6D] tracking-tight uppercase text-center mb-6 drop-shadow-sm"
                >
                    Misión
                </h3>
                <p
                    class="text-[#1a1a1a] font-bold text-base lg:text-lg leading-relaxed text-justify"
                >
                    Apoyar a Minera Escondida Ltda. en sus procesos productivos
                    con calidad, seguridad y protección del medio ambiente.
                </p>
            </div>

            <!-- Visión -->
            <div class="flex flex-col">
                <h3
                    class="text-3xl lg:text-4xl font-black text-[#DE5B6D] tracking-tight uppercase text-center mb-6 drop-shadow-sm"
                >
                    Visión
                </h3>
                <p
                    class="text-[#1a1a1a] font-bold text-base lg:text-lg leading-relaxed text-justify"
                >
                    “Ser la Empresa de manufactura de insumos para la minería y
                    obra civiles, líder en el ámbito nacional, siendo
                    reconocidos como Empresa por excelencia y calidad de
                    nuestros servicios, trabajando con ética y profesionalismo”.
                </p>
            </div>

            <!-- Valores -->
            <div class="flex flex-col">
                <h3
                    class="text-3xl lg:text-4xl font-black text-[#DE5B6D] tracking-tight uppercase text-center mb-6 drop-shadow-sm"
                >
                    Valores
                </h3>
                <p
                    class="text-[#1a1a1a] font-bold text-base lg:text-lg leading-relaxed text-justify"
                >
                    “Ser la Empresa de manufactura de insumos para la minería y
                    obra civiles, líder en el ámbito nacional, siendo
                    reconocidos como Empresa por excelencia y calidad de
                    nuestros servicios, trabajando con ética y profesionalismo”.
                </p>
            </div>
        </div>
        <LineaDivisor />

        <!-- Calidad y Certificados -->
        <div
            class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-start mt-16 lg:mt-24"
        >
            <!-- Calidad en los Servicios -->
            <div class="flex flex-col">
                <h2
                    class="text-3xl md:text-4xl lg:text-[40px] font-black text-[#DE5B6D] tracking-tight uppercase leading-tight text-center mb-6 drop-shadow-sm"
                >
                    CALIDAD EN LOS<br />SERVICIOS
                </h2>
                <p
                    class="text-gray-500 font-medium leading-relaxed text-base lg:text-lg text-justify max-w-xl mx-auto lg:mx-0"
                >
                    <strong class="text-gray-600 font-bold"
                        >JAM, Ingeniería, Construcción y Servicio</strong
                    >, con la finalidad de mejorar sus procesos y para
                    satisfacer los requerimientos de nuestros clientes ha
                    desarrollado e implementado un Sistema de Gestión integrado
                    bajo las Normas ISO.
                </p>
            </div>

            <!-- Certificado Bureau Veritas -->
            <div class="flex flex-col items-center">
                <h2
                    class="text-3xl md:text-4xl lg:text-[40px] font-black text-[#DE5B6D] tracking-tight uppercase leading-tight text-center mb-8 drop-shadow-sm"
                >
                    CERTIFICADO BUREAU VERITAS
                </h2>
                <div
                    class="flex flex-col sm:flex-row items-center justify-center gap-8 w-full"
                >
                    <!-- Sello Bureau Veritas (Imagen) -->
                    <div class="w-48 sm:w-56 shrink-0">
                        <img
                            src={isoJam.src}
                            alt="Bureau Veritas Certification"
                            class="w-full object-contain drop-shadow-md"
                        />
                    </div>

                    <!-- Lista de Normas -->
                    <div class="flex flex-col gap-6">
                        <!-- ISO 9001 -->
                        <div
                            class="flex items-center gap-4 group cursor-default"
                        >
                            <div
                                class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full bg-white border-[2.5px] border-gray-200 shadow-sm flex items-center justify-center transition-colors duration-300 group-hover:bg-[#DE5B6D] group-hover:border-[#DE5B6D]"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="w-8 h-8 md:w-10 md:h-10 text-[#DE5B6D] transition-colors duration-300 group-hover:text-white"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="flex flex-col text-left">
                                <span
                                    class="font-black text-[#1a1a1a] text-sm sm:text-base leading-tight"
                                    >ISO 9001:2008</span
                                >
                                <span
                                    class="text-gray-500 font-bold text-xs sm:text-sm"
                                    >Gestión de la calidad</span
                                >
                            </div>
                        </div>

                        <!-- ISO 14001 -->
                        <div
                            class="flex items-center gap-4 group cursor-default"
                        >
                            <div
                                class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full bg-white border-[2.5px] border-gray-200 shadow-sm flex items-center justify-center transition-colors duration-300 group-hover:bg-[#DE5B6D] group-hover:border-[#DE5B6D]"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="w-8 h-8 md:w-10 md:h-10 text-[#DE5B6D] transition-colors duration-300 group-hover:text-white"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="flex flex-col text-left">
                                <span
                                    class="font-black text-[#1a1a1a] text-sm sm:text-base leading-tight"
                                    >ISO 14001:2004:</span
                                >
                                <span
                                    class="text-gray-500 font-bold text-xs sm:text-sm"
                                    >Medio Ambiente y Estándar</span
                                >
                            </div>
                        </div>

                        <!-- OHSAS 18001 -->
                        <div
                            class="flex items-center gap-4 group cursor-default"
                        >
                            <div
                                class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full bg-white border-[2.5px] border-gray-200 shadow-sm flex items-center justify-center transition-colors duration-300 group-hover:bg-[#DE5B6D] group-hover:border-[#DE5B6D]"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="w-8 h-8 md:w-10 md:h-10 text-[#DE5B6D] transition-colors duration-300 group-hover:text-white"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="flex flex-col text-left">
                                <span
                                    class="font-black text-[#1a1a1a] text-sm sm:text-base leading-tight"
                                    >OHSAS 18001:2007:</span
                                >
                                <span
                                    class="text-gray-500 font-bold text-xs sm:text-sm leading-tight mt-0.5"
                                    >Sistemas de Gestión en<br />Seguridad y
                                    Salud Ocupacional</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <LineaDivisor />

        <!-- Infraestructura -->
        <div class="max-w-7xl mx-auto px-6 lg:px-12 mt-16 lg:mt-24 pb-16 lg:pb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center mb-12">
                <h2 class="text-3xl md:text-4xl lg:text-[40px] font-black text-[#DE5B6D] tracking-tight leading-tight text-left drop-shadow-sm uppercase">
                    Infraestructura de la<br/>Organizacion de JAM
                </h2>
                <p class="text-gray-500 font-bold leading-relaxed text-base lg:text-lg text-justify md:text-right">
                    La Gerencia JAM Ingeniería, Construcción y Servicio ha destinado los recursos necesarios para mejorar la infraestructura de la Organización y desarrollar la competencia de los cargos operativos de la organización.
                </p>
            </div>

            <!-- Image Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8 lg:gap-10 max-w-3xl mx-auto mt-12">
                {[img1, img2, img3, img4, img5, img6].map((img, index) => (
                    <div class="overflow-hidden bg-gray-100 shadow-md cursor-pointer group aspect-[4/3] rounded-sm relative" data-gallery-img>
                        <img src={img.src} alt={`Infraestructura ${index + 1}`} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                        <!-- Lupa Icon Hover Overlay -->
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                            </svg>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300">
        <!-- Close btn -->
        <button id="lightbox-close" class="absolute top-4 right-4 md:top-8 md:right-8 text-white/70 hover:text-white transition-colors z-[110] p-2 bg-black/50 hover:bg-[#DE5B6D] rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        
        <!-- Prev btn -->
        <button id="lightbox-prev" class="absolute left-2 md:left-8 text-white/70 hover:text-white transition-colors z-[110] p-3 bg-black/50 hover:bg-[#DE5B6D] rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-12 md:h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
        </button>
        
        <!-- Image container -->
        <div class="relative w-full h-full max-h-[90vh] flex items-center justify-center px-16 md:px-32 select-none">
            <img id="lightbox-img" src="" alt="Vista ampliada" class="max-w-full max-h-full object-contain shadow-2xl transition-transform duration-300 scale-95" />
        </div>
        
        <!-- Next btn -->
        <button id="lightbox-next" class="absolute right-2 md:right-8 text-white/70 hover:text-white transition-colors z-[110] p-3 bg-black/50 hover:bg-[#DE5B6D] rounded-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-12 md:h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
        </button>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const galleryItems = document.querySelectorAll('[data-gallery-img]');
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img');
            const btnClose = document.getElementById('lightbox-close');
            const btnPrev = document.getElementById('lightbox-prev');
            const btnNext = document.getElementById('lightbox-next');
            
            if(!lightbox || galleryItems.length === 0) return;

            let currentIndex = 0;
            const imageUrls = Array.from(galleryItems).map(item => item.querySelector('img').src);

            galleryItems.forEach((item, index) => {
                item.addEventListener('click', () => {
                    currentIndex = index;
                    openLightbox();
                });
            });

            function openLightbox() {
                updateImage();
                lightbox.classList.remove('hidden');
                lightbox.classList.add('flex');
                
                // Allow flex to apply before transitioning opacity
                setTimeout(() => {
                    lightbox.classList.remove('opacity-0');
                    lightboxImg.classList.remove('scale-95');
                    lightboxImg.classList.add('scale-100');
                }, 20);
                document.body.style.overflow = 'hidden';
            }

            function closeLightbox() {
                lightbox.classList.add('opacity-0');
                lightboxImg.classList.remove('scale-100');
                lightboxImg.classList.add('scale-95');
                
                setTimeout(() => {
                    lightbox.classList.remove('flex');
                    lightbox.classList.add('hidden');
                }, 300);
                document.body.style.overflow = '';
            }

            function updateImage() {
                lightboxImg.src = imageUrls[currentIndex];
            }

            function showPrev(e) {
                if(e) e.stopPropagation();
                currentIndex = (currentIndex === 0) ? imageUrls.length - 1 : currentIndex - 1;
                updateImage();
            }

            function showNext(e) {
                if(e) e.stopPropagation();
                currentIndex = (currentIndex === imageUrls.length - 1) ? 0 : currentIndex + 1;
                updateImage();
            }

            btnClose.addEventListener('click', closeLightbox);
            btnPrev.addEventListener('click', showPrev);
            btnNext.addEventListener('click', showNext);

            // Close on background click
            lightbox.addEventListener('click', (e) => {
                if (e.target === lightbox || e.target.closest('div.relative')) {
                    if(e.target.tagName !== 'IMG' && e.target.tagName !== 'BUTTON' && !e.target.closest('button')) {
                        closeLightbox();
                    }
                }
            });

            // Keyboard navigation
            document.addEventListener('keydown', (e) => {
                if (lightbox.classList.contains('hidden')) return;
                if (e.key === 'Escape') closeLightbox();
                if (e.key === 'ArrowLeft') showPrev();
                if (e.key === 'ArrowRight') showNext();
            });
        });
    </script>
</Layout>
