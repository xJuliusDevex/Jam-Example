---
import bg from "../assets/page/bg.jpg";
---

<!-- Right Side Card -->
<div
    class="relative w-[200px] sm:w-[240px] h-[230px] sm:h-[270px] mt-24 sm:mt-28 md:mt-24 lg:mt-20 xl:mt-24 ml-auto shrink-0 transform scale-90 sm:scale-100 origin-right"
>
    <!-- Background shadow box -->
    <div
        class="absolute top-3 bottom-3 -left-3.5 -right-3.5 bg-[#E8E8E8] rounded-2xl z-0"
    >
    </div>

    <!-- Main Card -->
    <div
        class="absolute inset-0 bg-white rounded-2xl z-10 shadow-2xl p-2 flex flex-col"
    >
        <img
            src={bg.src}
            alt="Trabajador"
            class="w-full h-28 object-cover rounded-xl"
        />

        <h3 class="text-xl font-medium text-black mt-3">¿Quienes somos?</h3>

        <div class="flex items-center justify-between mt-auto">
            <!-- Pagination dots/bars -->
            <div class="flex items-center gap-1.5">
                <div class="w-2 h-2 rounded-full bg-[#DE5B6D]"></div>
                <div class="w-2 h-2 rounded-full bg-[#DE5B6D]"></div>
                <div class="w-2 h-2 rounded-full bg-[#DE5B6D]"></div>
                <div class="w-6 h-2 rounded-full bg-[#DE5B6D]"></div>
                <div class="w-4 h-2 rounded-full bg-[#F4F4F4]"></div>
            </div>

            <!-- Arrow Button -->
            <button
                class="w-8 h-8 bg-[#F6D2D4] text-[#DE5B6D] rounded-full flex items-center justify-center hover:bg-[#DE5B6D] hover:text-white transition group"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M7 17L17 7M17 7v8M17 7H9"></path>
                </svg>
            </button>
        </div>
    </div>
</div>
