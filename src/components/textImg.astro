---
const { isoJam } = Astro.props;
---

<!-- Calidad y Certificados -->
<div
    id="text-img-container"
    class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-start mt-16 lg:mt-24 overflow-hidden"
>
    <!-- Calidad en los Servicios -->
    <div class="text-img-left flex flex-col opacity-0 -translate-x-[50px] transition-all duration-1000 ease-out">
        <h2
            class="text-3xl md:text-4xl lg:text-[40px] font-black text-[#DE5B6D] tracking-tight uppercase leading-tight text-center mb-6 drop-shadow-sm"
        >
            CALIDAD EN LOS<br />SERVICIOS
        </h2>
        <p
            class="text-gray-500 font-medium leading-relaxed text-base lg:text-lg text-justify max-w-xl mx-auto lg:mx-0"
        >
            <strong class="text-gray-600 font-bold"
                >JAM, Ingeniería, Construcción y Servicio</strong
            >, con la finalidad de mejorar sus procesos y para satisfacer los
            requerimientos de nuestros clientes ha desarrollado e implementado
            un Sistema de Gestión integrado bajo las Normas ISO.
        </p>
    </div>

    <!-- Certificado Bureau Veritas -->
    <div class="text-img-right flex flex-col items-center opacity-0 translate-x-[50px] transition-all duration-1000 delay-200 ease-out">
        <h2
            class="text-3xl md:text-4xl lg:text-[40px] font-black text-[#DE5B6D] tracking-tight uppercase leading-tight text-center mb-8 drop-shadow-sm"
        >
            CERTIFICADO BUREAU VERITAS
        </h2>
        <div
            class="flex flex-col sm:flex-row items-center justify-center gap-8 w-full"
        >
            <!-- Sello Bureau Veritas (Imagen) -->
            <div class="w-48 sm:w-56 shrink-0">
                <img
                    src={isoJam.src}
                    alt="Bureau Veritas Certification"
                    class="w-full object-contain drop-shadow-md"
                />
            </div>

            <!-- Lista de Normas -->
            <div class="flex flex-col gap-6">
                <!-- ISO 9001 -->
                <div class="flex items-center gap-4 group cursor-default">
                    <div
                        class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full bg-white border-[2.5px] border-gray-200 shadow-sm flex items-center justify-center transition-colors duration-300 group-hover:bg-[#DE5B6D] group-hover:border-[#DE5B6D]"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-8 h-8 md:w-10 md:h-10 text-[#DE5B6D] transition-colors duration-300 group-hover:text-white"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2.5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                            ></path>
                        </svg>
                    </div>
                    <div class="flex flex-col text-left">
                        <span
                            class="font-black text-[#1a1a1a] text-sm sm:text-base leading-tight"
                            >ISO 9001:2008</span
                        >
                        <span class="text-gray-500 font-bold text-xs sm:text-sm"
                            >Gestión de la calidad</span
                        >
                    </div>
                </div>

                <!-- ISO 14001 -->
                <div class="flex items-center gap-4 group cursor-default">
                    <div
                        class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full bg-white border-[2.5px] border-gray-200 shadow-sm flex items-center justify-center transition-colors duration-300 group-hover:bg-[#DE5B6D] group-hover:border-[#DE5B6D]"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-8 h-8 md:w-10 md:h-10 text-[#DE5B6D] transition-colors duration-300 group-hover:text-white"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2.5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                            ></path>
                        </svg>
                    </div>
                    <div class="flex flex-col text-left">
                        <span
                            class="font-black text-[#1a1a1a] text-sm sm:text-base leading-tight"
                            >ISO 14001:2004:</span
                        >
                        <span class="text-gray-500 font-bold text-xs sm:text-sm"
                            >Medio Ambiente y Estándar</span
                        >
                    </div>
                </div>

                <!-- OHSAS 18001 -->
                <div class="flex items-center gap-4 group cursor-default">
                    <div
                        class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full bg-white border-[2.5px] border-gray-200 shadow-sm flex items-center justify-center transition-colors duration-300 group-hover:bg-[#DE5B6D] group-hover:border-[#DE5B6D]"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-8 h-8 md:w-10 md:h-10 text-[#DE5B6D] transition-colors duration-300 group-hover:text-white"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2.5"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                            ></path>
                        </svg>
                    </div>
                    <div class="flex flex-col text-left">
                        <span
                            class="font-black text-[#1a1a1a] text-sm sm:text-base leading-tight"
                            >OHSAS 18001:2007:</span
                        >
                        <span
                            class="text-gray-500 font-bold text-xs sm:text-sm leading-tight mt-0.5"
                            >Sistemas de Gestión en<br />Seguridad y Salud
                            Ocupacional</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const container = document.getElementById("text-img-container");
        if (!container) return;

        const leftCol = container.querySelector(".text-img-left");
        const rightCol = container.querySelector(".text-img-right");

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        leftCol?.classList.remove("opacity-0", "-translate-x-[50px]");
                        leftCol?.classList.add("opacity-100", "translate-x-0");

                        rightCol?.classList.remove("opacity-0", "translate-x-[50px]");
                        rightCol?.classList.add("opacity-100", "translate-x-0");

                        observer.disconnect(); // Solo animar la primera vez
                    }
                });
            },
            { threshold: 0.15 }
        );

        observer.observe(container);
    });
</script>
