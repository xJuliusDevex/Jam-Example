---

---

<div
    id="title-izq-container"
    class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center overflow-hidden"
>
    <!-- Columna Izquierda: Títulos -->
    <div
        class="title-izq-left flex flex-col items-center justify-center text-center space-y-1 opacity-0 -translate-x-[50px] transition-all duration-1000 ease-out"
    >
        <h2
            class="text-3xl md:text-4xl lg:text-5xl font-black text-[#1a1a1a] tracking-tight uppercase"
        >
            ¿Quienes somos?
        </h2>
        <h3
            class="text-3xl md:text-4xl lg:text-5xl font-black text-[#DE5B6D] tracking-tight uppercase"
        >
            JAM
        </h3>
        <h4
            class="text-2xl md:text-3xl lg:text-4xl font-black text-[#1a1a1a] tracking-tight leading-tight uppercase pt-2"
        >
            Construcción, Ingeniería y<br />
            Servicios
        </h4>
    </div>

    <!-- Columna Derecha: Párrafo -->
    <div
        class="title-izq-right text-center text-gray-500 font-medium leading-relaxed text-base lg:text-lg max-w-xl mx-auto opacity-0 translate-x-[50px] transition-all duration-1000 delay-200 ease-out"
    >
        <p>
            <strong class="text-gray-600 font-bold"
                >JAM Construcción, Ingeniería y Servicio</strong
            >, fue creada el 14 de Octubre 1994 , con la finalidad de prestar
            servicios a las diferentes empresas de la zona norte del país. Su
            dependencia inicialmente se encontraba ubicada en Lautaro Espíndola
            #7024 y hoy en día sus oficinas administrativas y talleres
            operacionales en Los Topacios 680, Antofagasta.
        </p>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const container = document.getElementById("title-izq-container");
        if (!container) return;

        const leftCol = container.querySelector(".title-izq-left");
        const rightCol = container.querySelector(".title-izq-right");

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        leftCol?.classList.remove("opacity-0", "-translate-x-[50px]");
                        leftCol?.classList.add("opacity-100", "translate-x-0");

                        rightCol?.classList.remove("opacity-0", "translate-x-[50px]");
                        rightCol?.classList.add("opacity-100", "translate-x-0");

                        observer.disconnect(); // Solo animar la primera vez
                    }
                });
            },
            { threshold: 0.15 }
        );

        observer.observe(container);
    });
</script>
